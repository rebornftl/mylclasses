}

function logoutAdmin() {
  currentState.isAdmin = false;
  document.getElementById("adminNavItem").style.display = "none";
  document.getElementById("adminBottomItem").style.display = "none";
  showScreen("schedule");
}

function initAdminPanel() {
  renderProfilesList();
  onAdminClassChange();
  renderAdminLessons();
}

function onAdminClassChange() {
  const className = document.getElementById("adminClassSelect").value;
  const grade = className ? getGradeFromClass(className) : 0;
  
  // Группы математики
  const mathSelect = document.getElementById("adminMathGroupSelect");
  mathSelect.innerHTML = '<option value="">Без группы</option>';
  if (grade >= 7 && grade <= 11) {
    const groups = grade === 9 ? 3 : 2;
    for (let i = 1; i <= groups; i++) {
      mathSelect.innerHTML += `<option value="${i}">Группа ${i}</option>`;
    }
  }
  
  // Профили
  const profileSelect = document.getElementById("adminProfileSelect");
  profileSelect.innerHTML = '<option value="">Без профиля</option>';
  if (grade >= 9 && grade <= 11) {
    currentState.profiles.forEach(p => {
      profileSelect.innerHTML += `<option value="${p}">${p}</option>`;
    });
  }
  
  // Проверка домашнего обучения
  document.getElementById("remoteLearningCheck").checked = !!currentState.remoteClasses[className];
  
  renderAdminLessons();
}

function selectAdminDay(day) {
  if (day === 0) return;
  currentState.adminSelectedDay = day;
  document.querySelectorAll("#adminScreen .day-btn").forEach((btn, i) => {
    btn.classList.toggle("active", i + 1 === day);
  });
  renderAdminLessons();
}

function renderAdminLessons() {
  const className = document.getElementById("adminClassSelect").value;
  const container = document.getElementById("adminLessonsEditor");
  
  if (!className) {
    container.innerHTML = '<p style="color: var(--muted); text-align: center; padding: 60px; font-size: 16px;">Выберите класс</p>';
    return;
  }
  
  const group = document.getElementById("adminMathGroupSelect").value;
  const profile = document.getElementById("adminProfileSelect").value;
  const day = currentState.adminSelectedDay;
  const isSaturday = day === 6;
  
  const key = `${className}|${group}|${profile}|${day}`;
  const timetable = currentState.timetables[key] || { lessons: [] };
  
  // Загрузить специальные настройки
  document.getElementById("bigBreakLessonCheck").checked = timetable.hasBigBreakLesson || false;
  document.getElementById("ninthLessonCheck").checked = timetable.hasNinthLesson || false;
  document.getElementById("ninthLessonTimeSettings").classList.toggle("hidden", !timetable.hasNinthLesson);
  
  if (timetable.ninthTime) {
    const [startH, startM] = timetable.ninthTime.start.split(":");
    const [endH, endM] = timetable.ninthTime.end.split(":");
    document.getElementById("ninthStartH").value = startH;
    document.getElementById("ninthStartM").value = startM;
    document.getElementById("ninthEndH").value = endH;
    document.getElementById("ninthEndM").value = endM;
  }
  
  if (timetable.lessons.length === 0) {
    // Автозаполнение по умолчанию
    const timeConfig = isSaturday ? DEFAULT_TIMES.saturday : DEFAULT_TIMES.weekday;
    for (let i = 1; i <= 8; i++) {
      timetable.lessons.push({
        number: i,
        subject: "",
        cabinet: "",
        time: timeConfig[i]
      });
    }
  }
  
  container.innerHTML = timetable.lessons.map((lesson, idx) => `
    <div class="lesson-editor-row">
      <div style="font-weight: 800; color: var(--accent); font-size: 18px;">${lesson.number}</div>
      <input type="text" placeholder="Название предмета" value="${lesson.subject}" id="lesson-subj-${idx}" />
      <select id="lesson-cab-${idx}">
        <option value="">Каб.</option>
        ${generateCabinetOptions(lesson.cabinet)}
      </select>
      <input type="text" placeholder="08:00" value="${lesson.time?.start || ''}" id="lesson-start-${idx}" />
      <input type="text" placeholder="08:45" value="${lesson.time?.end || ''}" id="lesson-end-${idx}" />
      <button class="delete-lesson-btn" onclick="removeAdminLesson(${idx})">×</button>
    </div>
  `).join("");
}

function generateCabinetOptions(selected) {
  let html = "";
  for (let i = 1; i <= 23; i++) {
    html += `<option value="${i}" ${selected == i ? "selected" : ""}>${i}</option>`;
  }
  return html;
}

function addNewLesson() {
  const container = document.getElementById("adminLessonsEditor");
  const rows = container.querySelectorAll(".lesson-editor-row");
  const nextNum = rows.length + 1;
  
  const newRow = document.createElement("div");
  newRow.className = "lesson-editor-row";
  newRow.innerHTML = `
    <div style="font-weight: 800; color: var(--accent); font-size: 18px;">${nextNum}</div>
    <input type="text" placeholder="Название предмета" id="lesson-subj-${rows.length}" />
    <select id="lesson-cab-${rows.length}">
      <option value="">Каб.</option>
      ${generateCabinetOptions("")}
    </select>
    <input type="text" placeholder="15:30" value="15:30" id="lesson-start-${rows.length}" />
    <input type="text" placeholder="16:10" value="16:10" id="lesson-end-${rows.length}" />
    <button class="delete-lesson-btn" onclick="removeAdminLesson(${rows.length})">×</button>
  `;
  container.appendChild(newRow);
}

function removeAdminLesson(idx) {
  const container = document.getElementById("adminLessonsEditor");
  const rows = container.querySelectorAll(".lesson-editor-row");
  if (rows[idx]) {
    rows[idx].remove();
    // Перенумеровать
    container.querySelectorAll(".lesson-editor-row").forEach((row, i) => {
      row.querySelector("div").textContent = i + 1;
    });
  }
}

function clearAllLessons() {
  if (confirm("🗑 Удалить все уроки для этого дня?")) {
    document.getElementById("adminLessonsEditor").innerHTML = "";
  }
}

function toggleBigBreakLesson() {
  // Логика сохраняется при сохранении расписания
}

function toggleNinthLesson() {
  const checked = document.getElementById("ninthLessonCheck").checked;
  document.getElementById("ninthLessonTimeSettings").classList.toggle("hidden", !checked);
}

function toggleRemoteLearning() {
  const className = document.getElementById("adminClassSelect").value;
  if (document.getElementById("remoteLearningCheck").checked) {
    currentState.remoteClasses[className] = true;
  } else {
    delete currentState.remoteClasses[className];
  }
  localStorage.setItem(STORAGE_KEYS.REMOTE, JSON.stringify(currentState.remoteClasses));
}

function renderProfilesList() {
  const container = document.getElementById("profilesList");
  container.innerHTML = currentState.profiles.map((p, i) => `
    <span style="background: var(--accent-soft); color: var(--accent); padding: 10px 18px; border-radius: 999px; font-size: 14px; font-weight: 600; display: flex; align-items: center; gap: 10px; border: 1px solid var(--border);">
      ${p}
      <button onclick="removeProfile(${i})" style="background: none; border: none; color: var(--accent); cursor: pointer; padding: 0; font-size: 20px; line-height: 1; opacity: 0.6;">×</button>
    </span>
  `).join("");
}

function addProfile() {
  const name = document.getElementById("newProfileName").value.trim();
  if (name && !currentState.profiles.includes(name)) {
    currentState.profiles.push(name);
    localStorage.setItem(STORAGE_KEYS.PROFILES, JSON.stringify(currentState.profiles));
    document.getElementById("newProfileName").value = "";
    renderProfilesList();
    onAdminClassChange();
  } else if (currentState.profiles.includes(name)) {
    alert("Такой профиль уже существует");
  }
}

function removeProfile(idx) {
  if (confirm(`Удалить профиль "${currentState.profiles[idx]}"?`)) {
    currentState.profiles.splice(idx, 1);
    localStorage.setItem(STORAGE_KEYS.PROFILES, JSON.stringify(currentState.profiles));
    renderProfilesList();
    onAdminClassChange();
  }
}

function saveAdminTimetable() {
  const className = document.getElementById("adminClassSelect").value;
  if (!className) {
    alert("Выберите класс");
    return;
  }
  
  const group = document.getElementById("adminMathGroupSelect").value;
  const profile = document.getElementById("adminProfileSelect").value;
  const day = currentState.adminSelectedDay;
  
  const lessons = [];
  const rows = document.querySelectorAll("#adminLessonsEditor .lesson-editor-row");
  
  rows.forEach((row, idx) => {
    const subject = row.querySelector(`#lesson-subj-${idx}`)?.value?.trim() || "";
    if (!subject) return;
    
    const cabinet = row.querySelector(`#lesson-cab-${idx}`)?.value || "";
    const start = row.querySelector(`#lesson-start-${idx}`)?.value || "";
    const end = row.querySelector(`#lesson-end-${idx}`)?.value || "";
    
    lessons.push({
      number: idx + 1,
      subject,
      cabinet,
      time: { start, end }
    });
  });
  
  const key = `${className}|${group}|${profile}|${day}`;
  currentState.timetables[key] = {
    lessons,
    hasBigBreakLesson: document.getElementById("bigBreakLessonCheck").checked,
    hasNinthLesson: document.getElementById("ninthLessonCheck").checked,
    ninthTime: document.getElementById("ninthLessonCheck").checked ? {
      start: `${document.getElementById("ninthStartH").value}:${String(document.getElementById("ninthStartM").value).padStart(2, "0")}`,
      end: `${document.getElementById("ninthEndH").value}:${String(document.getElementById("ninthEndM").value).padStart(2, "0")}`
    } : null
  };
  
  localStorage.setItem(STORAGE_KEYS.TIMETABLES, JSON.stringify(currentState.timetables));
  
  const status = document.getElementById("adminSaveStatus");
  status.innerHTML = "✅ <b>Расписание успешно сохранено!</b>";
  status.style.color = "var(--success)";
  setTimeout(() => status.innerHTML = "", 4000);
}

// ============ ЗАГРУЗКА/СОХРАНЕНИЕ ============
function loadData() {
  // Студент
  const student = localStorage.getItem(STORAGE_KEYS.STUDENT);
  if (student) {
    const s = JSON.parse(student);
    currentState.studentClass = s.class;
    currentState.studentGroup = s.group;
    currentState.studentProfile = s.profile;
    currentState.dayView = s.dayView || "today";
    
    // Показать меню
    document.getElementById("calcNavItem").style.display = "flex";
    document.getElementById("settingsNavItem").style.display = "flex";
    document.getElementById("calcBottomItem").style.display = "flex";
    document.getElementById("settingsBottomItem").style.display = "flex";
  }
  
  // Оценки
  const grades = localStorage.getItem(STORAGE_KEYS.GRADES);
  if (grades) currentState.grades = JSON.parse(grades);
  
  // Расписания
  const timetables = localStorage.getItem(STORAGE_KEYS.TIMETABLES);
  if (timetables) currentState.timetables = JSON.parse(timetables);
  
  // Профили
  const profiles = localStorage.getItem(STORAGE_KEYS.PROFILES);
  if (profiles) {
    currentState.profiles = JSON.parse(profiles);
    PROFILES = currentState.profiles;
  }
  
  // Домашнее обучение
  const remote = localStorage.getItem(STORAGE_KEYS.REMOTE);
  if (remote) currentState.remoteClasses = JSON.parse(remote);
}
